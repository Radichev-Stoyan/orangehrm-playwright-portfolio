{
    "compilerOptions": {
        "target": "ES2021",
        "module": "Node16",
        "moduleResolution": "Node16",
        "lib": [
            "ES2021",
            "DOM"
        ],
        "types": [
            "node",
            "@playwright/test"
        ],
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "strict": true,
        "skipLibCheck": true,
        "noEmit": true
    },
    "include": [
        "tests/**/*.ts",
        "pages/**/*.ts",
        "utils/**/*.ts",
        "playwright.config.ts"
    ]
}